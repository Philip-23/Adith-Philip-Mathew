{
    "cleanUrls": true,
    "redirects": [
        {
            "source": "/index.html", 
            "destination": "/",
            "permanent": true
        }
    ],
    "headers": [
        {
            "source": "/**/*.{glb,gltf,bin"},
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "model/gltf-binary"
                },
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Cache-Control",
                    "value": "no-store, must-revalidate"                }
            ]
        }
    ]
}